{
  "name": "freak-lang",
  "displayName": "FREAK Language Support",
  "description": "Syntax highlighting, snippets, and language support for the FREAK programming language (.fk files)",
  "version": "0.1.0",
  "publisher": "freak-lang-dev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/FREAK-lang-dev/Freak-lang"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "activationEvents": [
    "onLanguage:freak"
  ],
  "main": "./extension.js",
  "categories": [
    "Programming Languages",
    "Snippets"
  ],
  "keywords": [
    "freak",
    "fk",
    "systems programming",
    "compiled",
    "anime"
  ],
  "contributes": {
    "languages": [
      {
        "id": "freak",
        "aliases": ["FREAK", "freak"],
        "extensions": [".fk"],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/freak-light.png",
          "dark": "./icons/freak-dark.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "freak",
        "scopeName": "source.freak",
        "path": "./syntaxes/freak.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "freak",
        "path": "./snippets/freak.json"
      }
    ],
    "configuration": {
      "title": "FREAK",
      "properties": {
        "freak.lsp.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable the FREAK language server (autocomplete, hover, diagnostics)"
        },
        "freak.lsp.pythonPath": {
          "type": "string",
          "default": "python",
          "description": "Path to Python interpreter for the LSP server"
        },
        "freak.lsp.serverPath": {
          "type": "string",
          "default": "",
          "description": "Path to freak_lsp.py (auto-detected if empty)"
        }
      }
    }
  }
}
