{
  "grammars": [
    {
      "name": "freak",
      "camelcase": "Freak",
      "scope": "source.freak",
      "path": ".",
      "file-types": [
        "fk"
      ],
      "highlights": "queries/highlights.scm",
      "injection-regex": "freak"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Tree-sitter grammar for the FREAK programming language",
    "links": {
      "repository": "https://github.com/tree-sitter/tree-sitter-freak"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true
  }
}
